# shellcheck shell=bash
# Idempotently make a pinned `uv` available on PATH. The shared CI agents don't
# reliably ship the version we want, so install it into ~/.local/bin (first on
# PATH below) and reuse it across builds.
#
# Meant to be sourced, not executed.

export PATH="$HOME/.local/bin:$PATH"

# The CI agents' system Python (/usr/local/bin/python3.11) is a CPython debug
# build (`--with-pydebug`, see base.Dockerfile), which is several times slower
# and makes the prefect ephemeral test server exceed its startup timeout. Force
# uv to use an optimized, managed (python-build-standalone) interpreter instead.
export UV_PYTHON_PREFERENCE=only-managed

# Pin uv for reproducible resolver behaviour. Install it (or replace a different
# version) into ~/.local/bin when the pinned version isn't already active.
UV_VERSION=0.11.18
if [ "$(uv --version 2>/dev/null | awk '{print $2}')" != "$UV_VERSION" ]; then
  echo "installing uv ${UV_VERSION}"
  curl -LsSf "https://astral.sh/uv/${UV_VERSION}/install.sh" | env UV_INSTALL_DIR="$HOME/.local/bin" sh
fi

uv --version
