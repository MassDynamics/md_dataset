#!/bin/bash

set -e

if [ -z "${CONDA_ENV_NAME}" ]; then
    echo "Error: CONDA_ENV_NAME environment variable is not set"
    exit 1
fi

if ! (( $(conda env list | grep "^${CONDA_ENV_NAME}[[:space:]]*" >/dev/null 2>&1)) ); then
  echo "creating conda environment ${CONDA_ENV_NAME}"
  conda create -y --name $CONDA_ENV_NAME python=3.11
fi

echo "installing packages into ${CONDA_ENV_NAME}"
# conda bundles an old pip (CVE-2026-3219, CVE-2026-6357); upgrade before auditing
conda run -n $CONDA_ENV_NAME bash -c "python -m pip install --upgrade 'pip>=26.1' && python -m pip install -e '.[dev]'"

echo "==Audit"
conda run --no-capture-output -n $CONDA_ENV_NAME pip-audit