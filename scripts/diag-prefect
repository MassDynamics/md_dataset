#!/bin/bash
# TEMPORARY diagnostic for the ephemeral-Prefect-API-server startup hang seen on
# CI under uv. pytest/xdist swallow the server subprocess output and prefect
# hardcodes `--log-level error`, so here we run the *same* uvicorn command in the
# foreground with debug logging under a timeout, to see where startup stalls.
#
# Mirrors prefect_test_harness exactly: a FRESH temp SQLite DB (not ~/.prefect).
# Run on the CI agent under uv. Delete once the issue is resolved.

set -e

source "$(dirname "$0")/ensure-uv"
uv sync --extra dev >/dev/null

echo "== interpreter =="
uv run python -c "import sys; print(sys.executable, sys.version)"

echo "== persistent prefect state on this agent =="
echo "PREFECT_HOME=${PREFECT_HOME:-$HOME/.prefect}"
ls -la "${PREFECT_HOME:-$HOME/.prefect}" 2>/dev/null || echo "  (no ~/.prefect)"
echo "-- active profile / profiles.toml --"
cat "${PREFECT_HOME:-$HOME/.prefect}/profiles.toml" 2>/dev/null || echo "  (no profiles.toml)"

# fresh temp DB, exactly like prefect_test_harness
TMP_DB_DIR=$(mktemp -d)
export PREFECT_API_DATABASE_CONNECTION_URL="sqlite+aiosqlite:///${TMP_DB_DIR}/prefect-test.db"
echo "== using fresh temp DB: $PREFECT_API_DATABASE_CONNECTION_URL =="

APP_DIR=$(uv run python -c "import prefect; print(prefect.__module_path__.parent)")

echo "== run the exact ephemeral-server uvicorn command, foreground, debug, 60s cap =="
echo "   success == 'Application startup complete'; if it hangs, note the LAST line."
PREFECT_UI_ENABLED=0 PREFECT__SERVER_EPHEMERAL=1 PREFECT__SERVER_FINAL=1 \
  timeout 60 uv run python -m uvicorn \
    --app-dir "$APP_DIR" \
    --factory prefect.server.api.server:create_app \
    --host 127.0.0.1 --port 8311 \
    --log-level debug --lifespan on \
  || echo "<< exited/timed out with status $? (124 = hit the 60s cap) >>"

rm -rf "$TMP_DB_DIR"