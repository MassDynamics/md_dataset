#!/bin/bash

# Scans a Docker image with Trivy for fixed HIGH/CRITICAL vulnerabilities,
# honouring suppressions in a .trivyignore file. Exits 1 (e.g failing CI) if
# any qualifying vulnerability is found, or if any suppression has expired.
#
# Trivy is pinned by digest; the image is cosign-verifiable. See the upgrade
# steps in the comment below before bumping the version.
#
# Usage:
#   ./scripts/trivy-scan-image <image_tag> <path/to/.trivyignore>

set -euo pipefail

IMAGE_TAG="${1:-}"
IGNORE_FILE="${2:-}"
SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )

if [[ -z "$IMAGE_TAG" || -z "$IGNORE_FILE" ]]; then
  echo "Usage: $0 <image_tag> <path/to/.trivyignore>" >&2
  exit 2
fi

if [[ ! -f "$IGNORE_FILE" ]]; then
  echo "Ignore file not found: $IGNORE_FILE" >&2
  exit 2
fi

echo "== Checking .trivyignore expiry..."
"${SCRIPT_DIR}/trivy-check-expiry" "$IGNORE_FILE"

echo "== Scanning docker image for vulnerabilities..."
# Trivy v0.71.0 pinned by digest. To upgrade, run locally:
#   cosign verify aquasec/trivy:<new-version> \
#     --certificate-identity-regexp '^https://github\.com/aquasecurity/trivy/' \
#     --certificate-oidc-issuer 'https://token.actions.githubusercontent.com'
#   docker pull aquasec/trivy:<new-version>
#   docker inspect --format='{{index .RepoDigests 0}}' aquasec/trivy:<new-version>
TRIVY_IMAGE=aquasec/trivy@sha256:016eae51fdcf989332a5404af7e8f625cd5d95d7c0907a221d080a996f556500

# Trivy's fs cache takes an exclusive lock. Parallel image builds on a shared
# agent that mount the same cache dir collide ("cache may be in use by another
# process"). Give each image its own cache dir (keyed off the repo part of the
# tag) so concurrent scans don't clash, while still reusing the vuln DB across
# rebuilds of that image.
CACHE_DIR="${HOME}/.cache/trivy/$(printf '%s' "${IMAGE_TAG%%:*}" | tr '/:' '__')"
mkdir -p "$CACHE_DIR"

# `--cache-backend memory` keeps the analysed-layer (scan) cache in-process so it
# never persists: each build scans a new tag, so that cache is never reused and
# would only accumulate. The vuln DB still persists in CACHE_DIR and self-refreshes,
# so each per-repo dir stays ~constant (just the DB) with no ongoing cleanup needed.
docker run --rm -i \
  -v /var/run/docker.sock:/var/run/docker.sock \
  -v "${CACHE_DIR}:/root/.cache/trivy/" \
  --entrypoint sh \
  "${TRIVY_IMAGE}" \
  -c "cat > /tmp/.trivyignore && exec trivy image --cache-backend memory --ignorefile /tmp/.trivyignore --exit-code 1 --severity HIGH,CRITICAL --ignore-unfixed ${IMAGE_TAG}" \
  < "$IGNORE_FILE"

